                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="footer text-muted">
        <div class="container">
            <a>&copy; 2026 - Mihail Milenkov</a>

            <a> - </a>

            <a href="https://www.linkedin.com/in/mihail-milenkov-543895243/" target="_blank"
               aria-label="LinkedIn" class="text-gray-400 hover:text-blue-600 transition-colors ml-[200px]">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor"
                     viewBox="0 0 24 24">
                    <path d="M4.98 3.5C4.98 4.88 3.88 6 2.5 6S0 4.88 0 3.5 1.12 1 2.5 1s2.48 1.12 2.48 2.5zM.5 8h4V24h-4V8zm7.5 0h3.7v2.16h.05c.52-.99 1.8-2.03 3.7-2.03 3.95 0 4.68 2.6 4.68 5.99V24h-4v-7.62c0-1.81-.03-4.15-2.53-4.15-2.54 0-2.93 1.98-2.93 4.02V24h-4V8z" />
                </svg>
            </a>

            <a> - </a>
            <a href="https://github.com/MihailMilenkov" target="_blank"
               aria-label="GitHub" class="text-gray-400 hover:text-white transition-colors ml-[200px]">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="black"
                     viewBox="0 0 24 24">
                    <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.84 10.91.57.1.78-.25.78-.55v-2.03c-3.19.7-3.86-1.53-3.86-1.53-.52-1.32-1.28-1.67-1.28-1.67-1.05-.72.08-.71.08-.71 1.16.08 1.77 1.2 1.77 1.2 1.03 1.77 2.7 1.26 3.36.96.1-.75.4-1.26.72-1.55-2.55-.29-5.23-1.28-5.23-5.7 0-1.26.45-2.3 1.19-3.12-.12-.3-.52-1.52.11-3.16 0 0 .97-.31 3.18 1.18a11.04 11.04 0 015.78 0c2.21-1.49 3.18-1.18 3.18-1.18.63 1.64.23 2.86.11 3.16.74.82 1.19 1.86 1.19 3.12 0 4.43-2.69 5.41-5.25 5.69.41.36.78 1.09.78 2.2v3.26c0 .3.21.66.79.55A10.51 10.51 0 0023.5 12c0-6.35-5.15-11.5-11.5-11.5z" />
